generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = "5"
  interface            = "asyncio"
}

datasource db {
  provider  = "postgresql"
  url       = env("CLOUD_DATABASE_URL")

}

model User {
  uuid                 String                 @id @default(dbgenerated("gen_random_uuid()")) @map("uuid") @db.Uuid
  n_id                 Int                    @unique @default(autoincrement()) @map("N_ID")
  created_at           DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  name                 String?                @map("Name")
  age                  Int?                   @map("Age")
  gender               String?                @map("Gender")
  national_id          String?                @map("National_ID")
  is_deleted           Boolean?               @default(false)
  assigned_doctor_uuid String?                @db.Uuid
  updated_at           DateTime?              @default(now()) @updatedAt @db.Timestamptz(6)
  DementiaScreenings   Dementia_Screening[]
  DepressionScreenings Depression_Screening[]
  physicalFrailty      PhysicalFrailty[]
  Reports              Report[]
  assignedDoctor       Admin?                 @relation("DoctorPatients", fields: [assigned_doctor_uuid], references: [uuid], onUpdate: NoAction, map: "fk_assigned_doctor")

  @@map("user")
}

model Depression_Screening {
  uuid          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_uuid     String?   @map("User_uuid") @db.Uuid
  Dep_test_id   Int       @unique @default(autoincrement())
  created_at    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  Q1_ans        Boolean?
  Q1_ans_score  Int?
  Q2_ans        Boolean?
  Q2_ans_score  Int?
  Q3_ans        Boolean?
  Q3_ans_score  Int?
  Q4_ans        Boolean?
  Q4_ans_score  Int?
  Q5_ans        Boolean?
  Q5_ans_score  Int?
  Q6_ans        Boolean?
  Q6_ans_score  Int?
  Q7_ans        Boolean?
  Q7_ans_score  Int?
  Q8_ans        Boolean?
  Q8_ans_score  Int?
  Q9_ans        Boolean?
  Q9_ans_score  Int?
  Q10_ans       Boolean?
  Q10_ans_score Int?
  Q11_ans       Boolean?
  Q11_ans_score Int?
  Q12_ans       Boolean?
  Q12_ans_score Int?
  Q13_ans       Boolean?
  Q13_ans_score Int?
  Q14_ans       Boolean?
  Q14_ans_score Int?
  Q15_ans       Boolean?
  Q15_ans_score Int?
  final_scores  Int?      @map("Final_scores")
  final_result  String?   @map("Final_result")
  user          User?     @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction)
  report        Report[]
}

model Dementia_Screening {
  uuid               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_uuid          String?   @map("User_uuid") @db.Uuid
  dem_test_id        Int       @unique @default(autoincrement()) @map("Dem_test_id")
  created_at         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  Q1_ans             String?
  Q1_P_point         Int?
  Q1_E_point         Int?
  Q2_ans             String?
  Q2_P_point         Int?
  Q2_E_point         Int?
  Q3_ans             String?
  Q3_P_point         Int?
  Q3_E_point         Int?
  Q4_ans             String?
  Q4_P_point         Int?
  Q4_E_point         Int?
  Q5_ans             String?
  Q5_P_point         Int?
  Q5_E_point         Int?
  Q6_ans             String?
  Q6_P_point         Int?
  Q6_E_point         Int?
  total_earned_point Int?      @map("Total_earned_point")
  final_result       String?   @map("Final_result")
  Q7_ans             String?
  Q7_P_point         Int?
  Q7_E_point         Int?
  Q8_ans             String?
  Q8_P_point         Int?
  Q8_E_point         Int?
  Q9_ans             String?
  Q9_P_point         Int?
  Q9_E_point         Int?
  Q10_ans            String?
  Q10_P_point        Int?
  Q10_E_point        Int?
  Q11_ans            String?
  Q11_P_point        Int?
  Q11_E_point        Int?
  Q12_ans            String?
  Q12_P_point        Int?
  Q12_E_point        Int?
  user               User?     @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction)
  report             Report[]
}

model PhysicalFrailty {
  uuid                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  User_uuid                      String    @db.Uuid
  PF_test_id                     Int       @unique @default(autoincrement()) @map("PF_test_id")
  Walking_speed                  Float?
  walking_speed_created_at       DateTime? @db.Timestamptz(6)
  walking_speed_is_done          Boolean?  @default(false)
  Functional_reach               Float?
  functional_reach_created_at    DateTime? @db.Timestamptz(6)
  functional_reach_is_done       Boolean?  @default(false)
  Standing_on_one_leg            Float?
  standing_on_one_leg_created_at DateTime? @db.Timestamptz(6)
  standing_on_one_leg_is_done    Boolean?  @default(false)
  Time_up_and_go                 Float?
  time_up_and_go_created_at      DateTime? @db.Timestamptz(6)
  time_up_and_go_is_done         Boolean?  @default(false)
  seated_forward_bend            Float?
  seated_forward_bend_created_at DateTime? @db.Timestamptz(6)
  seated_forward_bend_is_done    Boolean?  @default(false)
  grip_strength                  Float?
  grip_strength_created_at       DateTime? @db.Timestamptz(6)
  grip_strength_is_done          Boolean?  @default(false)
  created_at                     DateTime? @default(now()) @db.Timestamptz(6)
  session_date                   DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  session_status                 String?   @default("ACTIVE") @db.VarChar(20)
  session_submitted_at           DateTime? @db.Timestamptz(6)
  user                           User      @relation(fields: [User_uuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction)

  @@map("physical_frailty")
}

model Report {
  uuid                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  Report_test_id       Int                   @unique @default(autoincrement())
  user_uuid            String                @db.Uuid
  Dep_test_id          Int?
  Dem_test_id          Int?
  PF_test_id           Int?
  created_at           DateTime?             @default(now()) @db.Timestamptz(6)
  generated_by         String?               @db.Uuid
  updated_at           DateTime?             @default(now()) @updatedAt @db.Timestamptz(6)
  remarks              String?
  generator            Admin?                @relation("ReportGenerator", fields: [generated_by], references: [uuid], onUpdate: NoAction, map: "fk_generated_by")
  Dementia_Screening   Dementia_Screening?   @relation(fields: [Dem_test_id], references: [dem_test_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_report_dem")
  Depression_Screening Depression_Screening? @relation(fields: [Dep_test_id], references: [Dep_test_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_report_dep")
  user                 User                  @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction, map: "fk_report_user")

  @@map("report")
}

model Admin {
  uuid             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String    @db.VarChar(255)
  email            String    @unique @db.VarChar(255)
  password_hash    String
  role             String    @db.VarChar(20)
  is_active        Boolean?  @default(true)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  last_login       DateTime? @db.Timestamptz(6)
  generatedReports Report[]  @relation("ReportGenerator")
  assignedPatients User[]    @relation("DoctorPatients")

  @@map("admin")
}
